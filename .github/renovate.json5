{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "https://raw.githubusercontent.com/canonical/identity-credentials-workflows/refs/heads/v0/renovate.json5",
  ],
  baseBranchPatterns: ["main", "latest"],
  useBaseBranchConfig: "merge",
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: tempo_coordinator_k8s\\.charm_tracing[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "tempo_coordinator_k8s.charm_tracing",
      datasourceTemplate: "custom.charmhub-tempo-charm-tracing",
      versioningTemplate: "loose",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/charmcraft.yaml/"],
      matchStrings: [
        "- lib: tempo_coordinator_k8s\\.tracing[\\s\\S]*?version: [\"'](?<currentValue>[^\"']+)[\"']",
      ],
      depNameTemplate: "tempo_coordinator_k8s.tracing",
      datasourceTemplate: "custom.charmhub-tempo-tracing",
      versioningTemplate: "loose",
    },
  ],
  customDatasources: {
    "charmhub-tempo-charm-tracing": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/tempo-coordinator-k8s/01780f1e588c42c3976d26780fdf9b89?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
    "charmhub-tempo-tracing": {
      defaultRegistryUrlTemplate: "https://api.charmhub.io/v1/charm/libraries/tempo-coordinator-k8s/d2f02b1f8d1244b5989fd55bc3a28943?api=0",
      format: "json",
      transformTemplates: ['{"releases":[{"version": api & "." & patch}]}'],
    },
  },
}
